<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <ImageView
        android:id="@+id/glowBg"
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_gravity="center"
        android:src="@drawable/bg_glow_circle"
        android:alpha="0.5" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAppIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡"
            android:textSize="72sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEVEL UP BOT"
            android:textColor="@color/primary_blue"
            android:textSize="38sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.12"
            android:shadowColor="#00E5FF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="20" />

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Your Gaming Power Unleashed"
            android:textColor="@color/accent_cyan"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:alpha="0.0" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="200dp"
            android:layout_height="4dp"
            android:layout_marginTop="48dp"
            android:progress="0"
            android:max="100"
            android:progressTint="@color/accent_cyan"
            android:progressBackgroundTint="#1E2A6E"
            android:indeterminate="false" />

        <TextView
            android:id="@+id/tvLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Initializing..."
            android:textColor="@color/text_grey"
            android:textSize="12sp"
            android:letterSpacing="0.15" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:text="by ZuyCEO"
        android:textColor="#3A5090"
        android:textSize="12sp" />

</FrameLayout>
