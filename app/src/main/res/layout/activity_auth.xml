<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark">

    <ImageView
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-80dp"
        android:src="@drawable/bg_glow_circle"
        android:alpha="0.3" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡"
            android:textSize="52sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEVEL UP BOT"
            android:textColor="@color/primary_blue"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:shadowColor="#00E5FF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="15" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="40dp"
            android:text="Authentication Required"
            android:textColor="@color/text_grey"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/cardAuth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="24dp">

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input"
                android:hint="Username"
                android:textColorHint="@color/text_grey"
                android:textColor="@color/text_white"
                android:textSize="15sp"
                android:paddingHorizontal="20dp"
                android:inputType="text"
                android:singleLine="true"
                android:imeOptions="actionNext" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input"
                android:hint="Password"
                android:textColorHint="@color/text_grey"
                android:textColor="@color/text_white"
                android:textSize="15sp"
                android:paddingHorizontal="20dp"
                android:inputType="textPassword"
                android:singleLine="true"
                android:imeOptions="actionDone" />

            <TextView
                android:id="@+id/tvError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_gravity="center"
                android:text=""
                android:textColor="#FF1744"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_button_start"
                android:text="CONNECT"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:text="by ZuyCEO"
        android:textColor="#3A5090"
        android:textSize="12sp" />

</FrameLayout>
